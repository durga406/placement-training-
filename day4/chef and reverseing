t = int(input())
for i in range(t):
    n = int(input())
    a,b=[],[]
    for j in range(n):
        s = input()
        if s[7]==" ":
            a.append("Right on ") 
            b.append(s[8:]) 
        else:
            if s[0]!="B":
                a.append("Left on ")  
            else:
                a.append(s[:9]) 
            b.append(s[9:]) 
    b = b[::-1]  
    a[1:] = a[1:][::-1] 
    for k in range(n):
        print(a[k]+b[k]) 
        
