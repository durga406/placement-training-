N, M = map(int, input().split())
A = list(map(int, input().split()))

operations = []
for i in range(M):
    B, C = map(int, input().split())
    operations.append([C, B])

A.sort()
operations.sort(reverse=True)

card_index = 0

for C, B in operations:
    for count in range(B):
        if card_index < N and A[card_index] < C:
            A[card_index] = C
            card_index += 1
        else:
            break

print(sum(A))
