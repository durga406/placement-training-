class Solution(object):
    def longestCommonPrefix(self, strs):
        strs.sort()
        s=[]
        f=strs[0]
        l=strs[-1]
        for i in range(min(len(f),len(l))):
            if f[i]==l[i]:
                s.append(l[i])
            else:
                break
        return "".join(s)
        
        
